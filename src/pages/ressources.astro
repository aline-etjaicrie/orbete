  .rec-lux-card-v4[data-pillar="lancer"]   .rec-step { color: var(--pillar-lancer); background: rgba(59,130,246,0.08); }
  .rec-lux-card-v4[data-pillar="exister"]  .rec-step { color: var(--pillar-comprendre); background: rgba(139,92,246,0.08); }
  .rec-lux-card-v4[data-pillar="agir"]        .rec-step { color: var(--pillar-agir); background: rgba(16,185,129,0.08); }
  .rec-lux-card-v4[data-pillar="grandir"] .rec-step { color: var(--pillar-grandir); background: rgba(230,57,70,0.08); }

  .rec-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .rec-title-v4 {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--deep);
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .rec-promise-v4 {
    margin: 0;
    font-size: 0.88rem;
    color: #54636c;
    line-height: 1.5;
  }

  .rec-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .rec-pillar-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.38);
  }

  .rec-arrow {
    font-size: 1rem;
    color: rgba(10, 25, 47, 0.35);
    transition: all 0.2s;
  }

  .rec-lux-card-v4:hover .rec-arrow {
    color: var(--deep);
    transform: translateX(3px);
  }

  .path-section {
    background: white;
  }

  .path-highlight-card {
    background: var(--deep);
    color: #fff;
    padding: 3.6rem;
    border-radius: 40px;
    border: none;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
  }

  .path-badge {
    background: var(--neon);
    color: var(--deep);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border-radius: 99px;
    display: inline-block;
    margin-bottom: 1.6rem;
  }

  .path-title-v4 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 900;
    margin-bottom: 0.8rem;
    color: #fff;
    letter-spacing: -0.03em;
  }

  .path-promise-v4 {
    font-size: 1.15rem;
    color: #fff;
    opacity: 0.96;
    margin-bottom: 1rem;
    max-width: 42rem;
    line-height: 1.45;
  }

  .path-description-v4 {
    max-width: 42rem;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.6;
    margin-bottom: 2.4rem;
  }

  .path-priorities-box h3,
  .path-resources-box h3 {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--neon);
    letter-spacing: 0.1em;
    margin-bottom: 1.3rem;
  }

  .res-check-list-small {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-bottom: 2.6rem;
  }

  .res-check-list-small li {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    font-size: 1.06rem;
    font-weight: 600;
    color: #fff;
  }

  .check-icon-small {
    width: 0.48rem;
    height: 0.48rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: var(--neon);
    display: inline-block;
    margin-top: 0.38rem;
  }

  .path-mini-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .path-mini-card {
    background: rgba(255, 255, 255, 0.05);
    padding: 1.25rem;
    border-radius: 16px;
    text-decoration: none;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.2s;
  }

  .path-mini-card:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-3px);
  }

  .mini-format {
    font-size: 0.62rem;
    text-transform: uppercase;
    opacity: 0.56;
    font-weight: 800;
    margin-bottom: 0.3rem;
    display: block;
    letter-spacing: 0.08em;
  }

  .path-mini-card h4 {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.3;
  }

  .path-actions {
    margin-top: 2rem;
  }

  .explore-section {
    background: #F5F6F8;
  }

  .filter-shell {
    padding: 1.5rem;
    margin-bottom: 1.6rem;
    background: white;
    border-radius: 16px;
    border: 1px solid var(--border);
    box-shadow: 0 2px 12px rgba(10, 25, 47, 0.04);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .filter-search {
    position: relative;
  }

  .search-input {
    width: 100%;
    border: 1.5px solid rgba(10, 25, 47, 0.12);
    border-radius: 10px;
    background: #FAFAF8;
    color: var(--deep);
    font: inherit;
    font-size: 0.97rem;
    padding: 0.85rem 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus {
    border-color: var(--deep);
    background: white;
  }

  .filter-pills-section {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .filter-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.45);
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-pill {
    padding: 0.45rem 1rem;
    border-radius: 999px;
    border: 1.5px solid rgba(10, 25, 47, 0.12);
    background: #FAFAF8;
    color: #54636C;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.18s;
    white-space: nowrap;
  }

  .filter-pill:hover {
    border-color: var(--deep);
    color: var(--deep);
    background: white;
  }

  .filter-pill.active {
    background: var(--deep);
    color: white;
    border-color: var(--deep);
  }

  .filter-selects-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .filter-field {
    display: grid;
    gap: 0.45rem;
  }

  .filter-field select {
    width: 100%;
    border: 1.5px solid rgba(10, 25, 47, 0.12);
    border-radius: 10px;
    background: #FAFAF8;
    color: var(--deep);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.7rem 0.9rem;
    outline: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .filter-field select:focus {
    border-color: var(--deep);
    background: white;
  }

  .catalogue-head {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    margin: 1.5rem 0 1.2rem;
  }

  .resource-count {
    margin: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(10, 25, 47, 0.1);
    background: white;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.55);
    white-space: nowrap;
  }

  .catalog-actions {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  /* Pillar color palette */
  :root {
    --pillar-lancer: #1B4332;
    --pillar-comprendre: #8B5CF6;
    --pillar-agir: #10B981;
    --pillar-grandir: #D4A853;
  }

  .res-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: white;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(10, 25, 47, 0.04);
  }

  .res-lux-card {
    text-decoration: none;
    background: white;
    border-bottom: 1px solid var(--border);
    border-left: 3px solid transparent;
    border-radius: 0;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1rem 1.25rem 1rem 1.1rem;
    color: var(--deep);
  }

  .res-lux-card:last-child { border-bottom: none; }

  .res-lux-card[data-pillar="lancer"]   { border-left-color: var(--pillar-lancer); }
  .res-lux-card[data-pillar="exister"]  { border-left-color: var(--pillar-comprendre); }
  .res-lux-card[data-pillar="agir"]        { border-left-color: var(--pillar-agir); }
  .res-lux-card[data-pillar="grandir"] { border-left-color: var(--pillar-grandir); }

  .res-lux-card:hover { background: #F5F6F8; }

  .res-card-content {
    flex: 1;
    min-width: 0;
  }

  .res-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .res-card-kicker {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.4);
  }

  .res-lux-card[data-pillar="lancer"]   .res-card-kicker { color: var(--pillar-lancer); }
  .res-lux-card[data-pillar="exister"]  .res-card-kicker { color: var(--pillar-comprendre); }
  .res-lux-card[data-pillar="agir"]        .res-card-kicker { color: var(--pillar-agir); }
  .res-lux-card[data-pillar="grandir"] .res-card-kicker { color: var(--pillar-grandir); }

  .res-card-format-badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.35);
    background: rgba(10, 25, 47, 0.04);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  .res-card-title {
    font-size: 0.97rem;
    font-weight: 800;
    color: var(--deep);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .res-card-promise {
    font-size: 0.83rem;
    line-height: 1.4;
    color: #54636c;
    margin: 0.15rem 0 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .res-card-arrow {
    font-size: 0.95rem;
    color: rgba(10, 25, 47, 0.28);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .res-lux-card:hover .res-card-arrow {
    color: var(--deep);
    transform: translateX(3px);
  }

  .empty-state {
    margin-top: 1.2rem;
    padding: 1.6rem;
    border-radius: 1.4rem;
    border: 1px dashed rgba(10, 25, 47, 0.12);
    background: rgba(255, 255, 255, 0.72);
    text-align: center;
  }

  .empty-state p {
    margin: 0 0 1rem;
    color: #54636c;
  }

  .situations-section {
    background: white;
  }

  .sit-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(10, 25, 47, 0.04);
  }

  .sit-card {
    background: white;
    border: none;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    padding: 1.35rem 1.75rem;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    font: inherit;
    color: var(--deep);
  }

  .sit-card:last-child {
    border-bottom: none;
  }

  .sit-card:hover {
    background: #F5F6F8;
    transform: none;
    box-shadow: none;
  }

  .sit-card-content {
    flex: 1;
    min-width: 0;
  }

  .sit-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--deep);
    margin: 0 0 0.3rem;
    line-height: 1.24;
  }

  .sit-desc {
    font-size: 0.875rem;
    color: #54636c;
    line-height: 1.5;
    margin: 0;
  }

  .sit-footer {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .sit-link {
    display: none;
  }

  .sit-arrow {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(10, 25, 47, 0.05);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--deep);
    font-size: 0.95rem;
    flex-shrink: 0;
    transition: all 0.18s;
  }

  .sit-card:hover .sit-arrow {
    background: var(--deep);
    color: white;
  }

  .copilot-dark-section {
    background: var(--deep);
    padding: 5rem 0;
  }

  .copilot-dark-inner {
    padding: 0;
  }

  .copilot-dark-kicker {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--neon);
    margin-bottom: 1rem;
  }

  .copilot-dark-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.05;
  }

  .copilot-dark-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 48rem;
    margin: 0 0 2rem;
  }

  .copilot-dark-header {
    margin-bottom: 0.5rem;
  }

  .copilot-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 2.5rem;
  }

  .copilot-chip {
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.85);
    border-radius: 999px;
    padding: 0.65rem 1.1rem;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    transition: all 0.18s;
  }

  .copilot-chip:hover,
  .copilot-chip:focus-visible {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.3);
    color: white;
    outline: none;
  }

  .copilot-dark-btn {
    display: inline-block;
    padding: 0.9rem 2rem;
    background: var(--neon);
    color: var(--deep);
    border-radius: 10px;
    font-weight: 900;
    font-size: 1rem;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: all 0.2s;
  }

  .copilot-dark-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(173, 255, 47, 0.25);
  }

  .subtle-support-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    align-items: start;
    padding: 2rem 2.1rem;
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(10, 25, 47, 0.03) 0%, rgba(10, 25, 47, 0.01) 100%);
    border: 1px solid rgba(10, 25, 47, 0.08);
  }

  .subtle-support-copy h3 {
    margin: 1rem 0 0.8rem;
    font-size: 1.5rem;
    line-height: 1.25;
    color: var(--deep);
  }

  .subtle-support-copy p {
    margin: 0;
    color: #54636c;
    line-height: 1.6;
  }

  .subtle-support-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: flex-start;
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 25, 47, 0.8);
    backdrop-filter: blur(10px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .modal-card {
    background: white;
    width: 100%;
    max-width: 900px;
    max-height: 90vh;
    border-radius: 32px;
    position: relative;
    overflow-y: auto;
    padding: 4rem;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.3);
  }

  .modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: var(--bg);
    font-size: 1.5rem;
    cursor: pointer;
    transition: 0.2s;
  }

  .modal-close:hover {
    background: var(--red);
    color: white;
  }

  .modal-title {
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .modal-intro {
    font-size: 1.1rem;
    opacity: 0.8;
    line-height: 1.6;
    margin-bottom: 3rem;
  }

  .modal-body-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 4rem;
  }

  .modal-sub {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
  }

  .modal-list {
    list-style: none;
    padding: 0;
    margin-bottom: 3rem;
  }

  .modal-list li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
  }

  .modal-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--neon);
    transform: translateY(-50%);
  }

  .modal-res-grid {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .modal-res-link {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    background: var(--bg);
    border-radius: 12px;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: 0.2s;
  }

  .modal-res-link:hover {
    border-color: var(--red);
    background: white;
  }

  .modal-res-link .mini-title {
    font-weight: 700;
    color: var(--deep);
  }

  .aside-path-card {
    background: var(--deep);
    color: white;
    padding: 1.5rem;
    border-radius: 16px;
    margin-bottom: 2rem;
  }

  .aside-path-card h4 {
    font-size: 1.1rem;
    color: var(--neon);
    margin-bottom: 0.5rem;
  }

  .aside-path-card p {
    font-size: 0.85rem;
    opacity: 0.8;
    line-height: 1.45;
  }

  .cta-mini-box {
    background: #e6f3ff;
    padding: 2rem;
    border-radius: 20px;
  }

  .cta-label {
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #0077ed;
    margin-bottom: 0.5rem;
    display: block;
    letter-spacing: 0.08em;
  }

  .cta-mini-box p {
    font-size: 0.92rem;
    color: var(--deep);
    margin-bottom: 1.5rem;
  }

  .btn-tiny {
    padding: 0.6rem 1.2rem;
    font-size: 0.8rem;
  }

  @media (max-width: 1100px) {
    .diagnostic-helper-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .diagnostic-helper-actions {
      justify-content: flex-start;
    }

    .priority-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .filter-selects-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .path-mini-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .priority-grid,
    .rec-v4-grid,
    .res-grid,
    .filter-selects-row,
    .path-mini-grid,
    .modal-body-grid,
    .subtle-support-card {
      grid-template-columns: 1fr;
    }

    .catalogue-head {
      flex-direction: column;
      align-items: flex-start;
    }

    .path-highlight-card,
    .filter-shell {
      padding: 1.25rem;
    }

    .modal-card {
      padding: 2rem;
      border-radius: 20px;
      width: 95%;
    }

    .priority-situation-grid {
      grid-template-columns: 1fr;
    }

    .modal-title {
      font-size: 1.85rem;
    }
  }

  @media (max-width: 768px) {
    .section-v3 {
      padding: 4rem 0;
    }

    .res-hero-bg {
      padding-bottom: 4rem;
    }

    .diagnostic-helper-card {
      padding: 1.3rem;
      border-radius: 1.4rem;
    }

    .diagnostic-helper-actions {
      width: 100%;
    }

    .diagnostic-helper-actions .btn-primary-v3,
    .diagnostic-helper-actions .btn-secondary-v3 {
      width: 100%;
      justify-content: center;
    }

    .hero-note-card {
      padding: 1rem 1rem 1.05rem;
      border-radius: 1.2rem;
    }

    .priority-grid,
    .rec-v4-grid {
      grid-template-columns: 1fr;
    }

    .sit-card {
