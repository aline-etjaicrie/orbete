---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Diagnostic — Orbete"
  description="En 6 questions, Orbete identifie tes besoins prioritaires et te propose les ressources les plus utiles pour ton étape actuelle.">

  <main class="diag-root">

    <!-- ═══ INTRO ═══ -->
    <div id="view-intro" class="diag-view active">
      <div class="intro-bg" aria-hidden="true"></div>
      <div class="container-narrow">
        <div class="intro-shell">
          <span class="intro-badge">Diagnostic Orbete</span>
          <h1 class="intro-title">Fais le point<br/>sur ton activité.</h1>
          <p class="intro-lead">6 questions pour identifier ce qui t'aiderait le plus maintenant.</p>

          <ul class="intro-steps">
            <li>
              <span class="step-num">1</span>
              <span class="step-text">Une lecture claire de ta situation</span>
            </li>
            <li>
              <span class="step-num">2</span>
              <span class="step-text">Ton point de vigilance principal</span>
            </li>
            <li>
              <span class="step-num">3</span>
              <span class="step-text">Les ressources Orbete les plus utiles pour toi</span>
            </li>
          </ul>

          <button class="btn-cta" id="startBtn">
            Commencer le diagnostic
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
          <p class="intro-meta">3 minutes · Gratuit · Résultats enregistrés localement</p>
        </div>
      </div>
    </div>

    <!-- ═══ QUESTIONS ═══ -->
    <div id="view-questions" class="diag-view">

      <nav class="q-nav" id="diagNav">
        <div class="container-narrow">
          <div class="q-nav-inner">
            <button class="btn-back" id="prevBtn" aria-label="Question précédente">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
              <span>Retour</span>
            </button>
            <div class="steps-track" id="stepsTrack" aria-hidden="true"></div>
          </div>
        </div>
      </nav>

      <div class="container-narrow">
        <div class="question-slot" id="questionSlot">
          <!-- rendu par JS -->
        </div>
      </div>
    </div>

    <!-- ═══ CALCUL ═══ -->
    <div id="view-calc" class="diag-view">
      <div class="container-narrow">
        <div class="calc-shell">
          <div class="calc-ring">
            <div class="calc-spinner"></div>
          </div>
          <h2 class="calc-title">Analyse en cours…</h2>
          <p class="calc-sub">Orbete relie tes réponses pour faire ressortir ce qui t'aiderait le plus maintenant.</p>
        </div>
      </div>
    </div>

    <!-- ═══ RÉSULTAT ═══ -->
    <div id="view-result" class="diag-view">
      <div class="container-narrow">
        <div class="result-shell">

          <header class="res-head">
            <span class="res-badge">Ton diagnostic</span>
            <h2 class="res-headline" id="resHeadline">—</h2>
          </header>

          <div class="res-cards">

            <!-- SITUATION -->
            <div class="res-card">
              <p class="res-card-label">Ta situation aujourd'hui</p>
              <p class="res-card-text" id="resSituation"></p>
            </div>

            <!-- VIGILANCE -->
            <div class="res-card res-card--vigilance">
              <p class="res-card-label">Point de vigilance</p>
              <p class="res-card-text" id="resVigilance"></p>
            </div>

            <!-- AIDE -->
            <div class="res-card">
              <p class="res-card-label">Ce qui t'aiderait le plus</p>
              <ul class="res-helps" id="resHelps"></ul>
            </div>

          </div>

          <!-- PILIERS -->
          <div class="res-pillars-block">
            <p class="res-pillars-label">Les ressources Orbete pour toi</p>
            <p class="res-pillars-intro" id="resPillarsIntro"></p>
            <div class="pillars-grid" id="resPillarsGrid"></div>
          </div>

          <!-- ACTIONS -->
          <div class="res-actions">
            <a href="/ressources" class="btn-cta" id="resCtaResources">
              Explorer mes ressources
              <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/copilote" class="btn-outline">Poser une question au copilote →</a>
            <a href="/mon-compte" class="btn-ghost">Mon tableau de bord</a>
          </div>

          <div class="res-footer-link">
            <a href="/" class="btn-ghost dim">← Retour à l'accueil</a>
          </div>

        </div>
      </div>
    </div>

  </main>

  <style>
    /* ─── TOKENS ─── */
    :root {
      --deep:   #1B4332;
      --gold:   #D4A853;
      --bg:     #F9F6F0;
      --ink:    #1A1A1A;
      --muted:  rgba(26,26,26,0.52);
      --border: rgba(27,67,50,0.11);
      --r:      14px;
      --r-lg:   22px;
      --r-xl:   30px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .diag-root {
      min-height: 100vh;
      background: var(--bg);
      color: var(--ink);
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .diag-view { display: none; }
    .diag-view.active { display: block; }

    .container-narrow {
      max-width: 600px;
      margin: 0 auto;
      padding: 0 1.25rem;
      width: 100%;
    }

    /* ─── INTRO ─── */
    .intro-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 80% 60% at 50% -10%, rgba(27,67,50,0.09), transparent),
        radial-gradient(ellipse 55% 45% at 100% 80%, rgba(212,168,83,0.06), transparent);
    }

    #view-intro {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 5vh 0 6vh;
    }

    .intro-shell {
      position: relative;
      z-index: 1;
      width: 100%;
      padding: 3.5rem 0 2rem;
    }

    .intro-badge {
      display: inline-block;
      padding: 0.32rem 0.85rem;
      background: rgba(27,67,50,0.08);
      color: var(--deep);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border-radius: 999px;
      border: 1px solid var(--border);
      margin-bottom: 2rem;
    }

    .intro-title {
      font-size: clamp(2.4rem, 8vw, 3.6rem);
      font-weight: 900;
      line-height: 1.07;
      letter-spacing: -0.03em;
      color: var(--deep);
      margin-bottom: 1.25rem;
    }

    .intro-lead {
      font-size: 1.1rem;
      line-height: 1.65;
      color: var(--muted);
      margin-bottom: 3rem;
      max-width: 420px;
    }

    .intro-steps {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1.1rem;
      margin-bottom: 3.5rem;
    }

    .intro-steps li {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .step-num {
      flex-shrink: 0;
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: var(--deep);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .step-text {
      font-size: 0.98rem;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.4;
    }

    .btn-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      padding: 1.1rem 2.2rem;
      background: var(--deep);
      color: #fff;
      border: none;
      border-radius: var(--r-lg);
      font-size: 1.05rem;
      font-weight: 800;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
      box-shadow: 0 6px 22px rgba(27,67,50,0.22);
    }

    .btn-cta svg {
      width: 1.15rem;
      height: 1.15rem;
      stroke: currentColor;
      fill: none;
      stroke-width: 2.5;
      flex-shrink: 0;
      transition: transform 0.2s;
    }

    .btn-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(27,67,50,0.28);
    }

    .btn-cta:hover svg { transform: translateX(3px); }

    .intro-meta {
      margin-top: 1.25rem;
      font-size: 0.8rem;
      color: var(--muted);
      font-weight: 500;
    }

    /* ─── NAV QUESTIONS ─── */
    .q-nav {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(249,246,240,0.88);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }

    .q-nav-inner {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      background: none;
      border: none;
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--deep);
      cursor: pointer;
      padding: 0.35rem 0;
      opacity: 0.55;
      transition: opacity 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .btn-back:hover { opacity: 1; }

    .btn-back svg {
      width: 1rem;
      height: 1rem;
      flex-shrink: 0;
    }

    .steps-track {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.4rem;
    }

    .step-dot {
      width: 0.55rem;
      height: 0.55rem;
      border-radius: 50%;
      background: rgba(27,67,50,0.14);
      transition: background 0.3s, transform 0.3s;
    }

    .step-dot.done  { background: rgba(27,67,50,0.4); }
    .step-dot.current { background: var(--deep); transform: scale(1.35); }

    /* ─── QUESTION SLOT ─── */
    .question-slot {
      padding: 3.5rem 0 6rem;
      transition: opacity 0.22s ease, transform 0.22s ease;
    }

    .question-slot.exit {
      opacity: 0;
      transform: translateX(-20px);
    }

    .question-slot.enter {
      opacity: 0;
      transform: translateX(20px);
    }

    .q-counter {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.25rem;
    }

    .q-text {
      font-size: clamp(1.55rem, 5.5vw, 2.2rem);
      font-weight: 900;
      line-height: 1.18;
      letter-spacing: -0.025em;
      color: var(--deep);
      margin-bottom: 2.75rem;
    }

    .options {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
    }

    .opt {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      width: 100%;
      padding: 1.1rem 1.4rem;
      background: #fff;
      border: 1.5px solid rgba(27,67,50,0.1);
      border-radius: var(--r);
      text-align: left;
      font-size: 1rem;
      font-weight: 600;
      color: var(--ink);
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s, transform 0.15s, box-shadow 0.15s;
      line-height: 1.4;
      box-shadow: 0 1px 4px rgba(27,67,50,0.04);
    }

    .opt-check {
      flex-shrink: 0;
      width: 1.35rem;
      height: 1.35rem;
      border-radius: 50%;
      border: 2px solid rgba(27,67,50,0.18);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s, border-color 0.15s;
    }

    .opt-check svg {
      width: 0.65rem;
      height: 0.65rem;
      stroke: #fff;
      fill: none;
      stroke-width: 3;
      opacity: 0;
      transition: opacity 0.15s;
    }

    .opt:hover {
      border-color: var(--deep);
      background: rgba(27,67,50,0.03);
      transform: translateX(3px);
      box-shadow: 0 4px 14px rgba(27,67,50,0.08);
    }

    .opt:hover .opt-check {
      border-color: var(--deep);
    }

    .opt.selected {
      border-color: var(--deep);
      border-width: 2px;
      background: rgba(27,67,50,0.04);
      box-shadow: 0 4px 14px rgba(27,67,50,0.1);
    }

    .opt.selected .opt-check {
      background: var(--deep);
      border-color: var(--deep);
    }

    .opt.selected .opt-check svg {
      opacity: 1;
    }

    /* ─── CALC ─── */
    #view-calc {
      min-height: 100vh;
      display: flex;
      align-items: center;
    }

    .calc-shell {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 4rem 0;
      gap: 0;
    }

    .calc-ring {
      width: 4rem;
      height: 4rem;
      border-radius: 50%;
      border: 3px solid rgba(27,67,50,0.12);
      border-top-color: var(--gold);
      animation: spin 0.8s linear infinite;
      margin-bottom: 2.25rem;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .calc-title {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--deep);
      letter-spacing: -0.02em;
      margin-bottom: 0.9rem;
    }

    .calc-sub {
      font-size: 1rem;
      color: var(--muted);
      max-width: 380px;
      line-height: 1.65;
    }

    /* ─── RÉSULTAT ─── */
    #view-result { padding: 4vh 0 10vh; }

    .result-shell {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .res-head {
      padding: 2rem 0 2.5rem;
    }

    .res-badge {
      display: inline-block;
      padding: 0.28rem 0.8rem;
      background: rgba(27,67,50,0.08);
      color: var(--deep);
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border-radius: 999px;
      border: 1px solid var(--border);
      margin-bottom: 1.1rem;
    }

    .res-headline {
      font-size: clamp(1.7rem, 5.5vw, 2.5rem);
      font-weight: 900;
      line-height: 1.15;
      letter-spacing: -0.025em;
      color: var(--deep);
    }

    /* ─── CARDS RÉSULTAT ─── */
    .res-cards {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .res-card {
      background: #fff;
      border: 1px solid rgba(27,67,50,0.08);
      border-radius: var(--r-lg);
      padding: 1.75rem 1.85rem;
      box-shadow: 0 2px 12px rgba(27,67,50,0.05);
    }

    .res-card--vigilance {
      border-left: 4px solid var(--gold);
      background: rgba(212,168,83,0.04);
    }

    .res-card-label {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .res-card--vigilance .res-card-label {
      color: var(--deep);
      opacity: 0.7;
    }

    .res-card-text {
      font-size: 1.02rem;
      line-height: 1.7;
      color: #333;
    }

    .res-helps {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      padding: 0;
    }

    .res-helps li {
      display: flex;
      align-items: flex-start;
      gap: 0.85rem;
      font-size: 1rem;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.5;
    }

    .res-helps li::before {
      content: '';
      flex-shrink: 0;
      width: 1.1rem;
      height: 1.1rem;
      border-radius: 50%;
      background: var(--deep);
      margin-top: 0.18rem;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 12 12' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 6l3 3 5-5' stroke='white' stroke-width='1.8' fill='none' stroke-linecap='round'/%3E%3C/svg%3E");
      background-size: 65%;
      background-repeat: no-repeat;
      background-position: center;
    }

    /* ─── PILIERS ─── */
    .res-pillars-block {
      background: var(--deep);
      border-radius: var(--r-xl);
      padding: 2.5rem 2rem;
      margin: 1.25rem 0;
      color: #fff;
    }

    .res-pillars-label {
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .res-pillars-intro {
      font-size: 0.97rem;
      line-height: 1.65;
      opacity: 0.75;
      margin-bottom: 1.75rem;
    }

    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .pillar-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: var(--r);
      padding: 1.25rem 1.15rem;
      transition: background 0.18s;
    }

    .pillar-card.active {
      background: rgba(212,168,83,0.15);
      border-color: rgba(212,168,83,0.45);
    }

    .pillar-card-name {
      font-size: 0.95rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 0.4rem;
      letter-spacing: -0.01em;
    }

    .pillar-card.active .pillar-card-name {
      color: var(--gold);
    }

    .pillar-card-desc {
      font-size: 0.8rem;
      line-height: 1.45;
      opacity: 0.6;
      color: #fff;
    }

    /* ─── ACTIONS ─── */
    .res-actions {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      margin-top: 0.75rem;
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.75rem;
      background: transparent;
      color: var(--deep);
      border: 2px solid var(--border);
      border-radius: var(--r-lg);
      font-size: 0.97rem;
      font-weight: 700;
      text-decoration: none;
      transition: border-color 0.15s, background 0.15s;
      text-align: center;
    }

    .btn-outline:hover {
      border-color: var(--deep);
      background: rgba(27,67,50,0.04);
    }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 1.5rem;
      background: transparent;
      color: var(--deep);
      border: none;
      font-size: 0.9rem;
      font-weight: 700;
      text-decoration: none;
      opacity: 0.55;
      transition: opacity 0.15s;
    }

    .btn-ghost:hover { opacity: 1; }
    .btn-ghost.dim   { opacity: 0.35; }
    .btn-ghost.dim:hover { opacity: 0.7; }

    .res-footer-link {
      margin-top: 1.5rem;
      text-align: center;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 540px) {
      .intro-title { font-size: 2.15rem; }
      .btn-cta { width: 100%; justify-content: center; }
      .q-text { font-size: 1.45rem; }
      .pillars-grid { grid-template-columns: 1fr; }
      .res-pillars-block { padding: 2rem 1.5rem; border-radius: var(--r-lg); }
      .res-card { padding: 1.4rem 1.4rem; }
      .btn-outline { width: 100%; }
    }
  </style>

  <script is:inline>
    /* ────────────────────────────────────────────
       DATA
    ──────────────────────────────────────────── */
    var QUESTIONS = [
      {
        key: 'avancement',
        label: 'Tu en es où dans ton projet ?',
        options: [
          { value: 'idee',          label: "J'ai une idée en cours" },
          { value: 'lance_recent',  label: "Lancé·e depuis moins d'un an" },
          { value: 'en_dev',        label: 'En développement' },
          { value: 'bien_installe', label: 'Bien installé·e' }
        ]
      },
      {
        key: 'statut',
        label: 'Ton statut juridique ?',
        options: [
          { value: 'pas_encore', label: 'Pas encore de statut' },
          { value: 'micro',      label: 'Micro-entrepreneur' },
          { value: 'societe',    label: 'Société (SASU, EURL, SAS…)' },
          { value: 'asso',       label: 'Association' },
          { value: 'autre',      label: 'Autre' }
        ]
      },
      {
        key: 'secteur',
        label: "Ton secteur d'activité ?",
        options: [
          { value: 'artisanat', label: 'Métier manuel / artisanat' },
          { value: 'art',       label: 'Création artistique' },
          { value: 'service',   label: 'Service aux particuliers ou aux pros' },
          { value: 'commerce',  label: 'Commerce' },
          { value: 'autre',     label: 'Autre' }
        ]
      },
      {
        key: 'frein',
        label: 'Ton plus grand frein en ce moment ?',
        options: [
          { value: 'demarches', label: 'Les démarches administratives' },
          { value: 'visibilite', label: 'Me faire connaître' },
          { value: 'clients',   label: 'Trouver des clients' },
          { value: 'finances',  label: 'Gérer les finances' },
          { value: 'isolement', label: "L'isolement" }
        ]
      },
      {
        key: 'priorite',
        label: 'Ce que tu veux développer en priorité ?',
        options: [
          { value: 'structurer', label: 'Structurer mon activité' },
          { value: 'visibilite', label: 'Développer ma visibilité' },
          { value: 'gestion',    label: 'Mieux gérer mon quotidien' },
          { value: 'reseau',     label: 'Agrandir mon réseau' }
        ]
      },
      {
        key: 'lieu',
        label: 'Tu es installé·e dans quel lieu Be-Cosmo ?',
        options: [
          { value: 'hermite',    label: 'Charles Hermite — Paris 18e' },
          { value: 'cargo',      label: 'Le Cargo — Paris 19e' },
          { value: 'montreuil',  label: 'Porte de Montreuil — Paris 20e' },
          { value: 'pas_encore', label: 'Pas encore' },
          { value: 'autre',      label: 'Autre' }
        ]
      }
    ];

    var PILLARS = {
      lancer:  { name: 'Lancer',  desc: 'Créer sa structure, statut juridique, aides à la création' },
      exister: { name: 'Exister', desc: 'Communication, offre, visibilité, pitch' },
      gerer:   { name: 'Gérer',   desc: 'Admin, URSSAF, facturation, aides financières' },
      grandir: { name: 'Grandir', desc: 'Réseau, partenaires, développement' }
    };

    /* ────────────────────────────────────────────
       STATE
    ──────────────────────────────────────────── */
    var currentStep = 0;
    var answers = {};
    var N = QUESTIONS.length;

    /* ────────────────────────────────────────────
       VIEWS
    ──────────────────────────────────────────── */
    function showView(id) {
      document.querySelectorAll('.diag-view').forEach(function(v) {
        v.classList.remove('active');
      });
      var el = document.getElementById(id);
      if (el) el.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    /* ────────────────────────────────────────────
       STEP DOTS
    ──────────────────────────────────────────── */
    function renderDots(idx) {
      var track = document.getElementById('stepsTrack');
      if (!track) return;
      track.innerHTML = '';
      for (var i = 0; i < N; i++) {
        var d = document.createElement('span');
        d.className = 'step-dot' + (i < idx ? ' done' : i === idx ? ' current' : '');
        track.appendChild(d);
      }
    }

    /* ────────────────────────────────────────────
       QUESTION RENDERING
    ──────────────────────────────────────────── */
    function renderQuestion(idx, direction) {
      var slot = document.getElementById('questionSlot');
      var q = QUESTIONS[idx];

      var html = '<p class="q-counter">Question ' + (idx + 1) + ' sur ' + N + '</p>'
               + '<h2 class="q-text">' + escHtml(q.label) + '</h2>'
               + '<div class="options" role="list">';

      q.options.forEach(function(opt) {
        var isSelected = answers[q.key] === opt.value;
        html += '<button class="opt' + (isSelected ? ' selected' : '') + '" '
              + 'onclick="pickAnswer(\'' + esc(q.key) + '\',\'' + esc(opt.value) + '\')">'
              + escHtml(opt.label)
              + '<span class="opt-check" aria-hidden="true">'
              + '<svg viewBox="0 0 12 12" xmlns="http://www.w3.org/2000/svg"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" fill="none" stroke-linecap="round"/></svg>'
              + '</span>'
              + '</button>';
      });

      html += '</div>';

      if (direction !== 0) {
        slot.classList.add('exit');
      }

      setTimeout(function() {
        slot.innerHTML = html;
        slot.classList.remove('exit');
        slot.classList.add('enter');
        void slot.offsetWidth;
        slot.classList.remove('enter');
      }, direction !== 0 ? 200 : 0);
    }

    /* ────────────────────────────────────────────
       NAVIGATION
    ──────────────────────────────────────────── */
    function pickAnswer(key, value) {
      document.querySelectorAll('.opt').forEach(function(btn) {
        btn.classList.remove('selected');
      });
      if (event && event.currentTarget) {
        event.currentTarget.classList.add('selected');
      }

      answers[key] = value;

      if (currentStep < N - 1) {
        currentStep++;
        setTimeout(function() {
          renderDots(currentStep);
          renderQuestion(currentStep, 1);
        }, 230);
      } else {
        showView('view-calc');
        setTimeout(processDiagnosis, 1600);
      }
    }

    function goPrev() {
      if (currentStep > 0) {
        currentStep--;
        renderDots(currentStep);
        renderQuestion(currentStep, -1);
      } else {
        showView('view-intro');
      }
    }

    /* ────────────────────────────────────────────
       SCORING
    ──────────────────────────────────────────── */
    function computePillarScores(a) {
      var s = { lancer: 0, exister: 0, gerer: 0, grandir: 0 };

      if (a.avancement === 'idee')          { s.lancer += 4; }
      if (a.avancement === 'lance_recent')  { s.lancer += 3; s.gerer += 1; }
      if (a.avancement === 'en_dev')        { s.exister += 1; s.gerer += 1; s.grandir += 1; }
      if (a.avancement === 'bien_installe') { s.grandir += 2; s.exister += 1; }

      if (a.statut === 'pas_encore') { s.lancer += 4; }
      if (a.statut === 'micro')      { s.lancer += 1; s.gerer += 2; }
      if (a.statut === 'societe')    { s.gerer += 2; }
      if (a.statut === 'asso')       { s.gerer += 1; s.grandir += 1; }

      if (a.frein === 'demarches')  { s.lancer += 3; s.gerer += 2; }
      if (a.frein === 'visibilite') { s.exister += 4; }
      if (a.frein === 'clients')    { s.exister += 2; s.grandir += 2; }
      if (a.frein === 'finances')   { s.gerer += 4; }
      if (a.frein === 'isolement')  { s.grandir += 4; }

      if (a.priorite === 'structurer') { s.lancer += 2; }
      if (a.priorite === 'visibilite') { s.exister += 3; }
      if (a.priorite === 'gestion')    { s.gerer += 3; }
      if (a.priorite === 'reseau')     { s.grandir += 3; }

      return s;
    }

    function topPillars(scores, n) {
      return Object.keys(scores)
        .sort(function(a, b) { return scores[b] - scores[a]; })
        .slice(0, n || 2);
    }

    function buildSituation(a) {
      if (a.avancement === 'idee') {
        return "Tu es en phase d'exploration. Ton projet prend forme mais il reste encore beaucoup à clarifier — statut, offre, premiers clients. C'est une étape charnière où les bons repères font gagner beaucoup de temps.";
      }
      if (a.avancement === 'lance_recent') {
        return "Tu as franchi le premier cap : ton activité est lancée. La priorité maintenant, c'est de consolider les fondations — administrative, commerciale, financière — pour ne pas avancer à tâtons.";
      }
      if (a.avancement === 'en_dev') {
        return "Ton activité tourne, mais tu veux aller plus loin. Le défi n'est plus de démarrer, c'est de structurer ce qui existe pour crescendo : visibilité, organisation, réseau.";
      }
      return "Tu as posé des bases solides. L'enjeu maintenant c'est de capitaliser sur ce qui fonctionne, d'élargir ton réseau et de passer un cap — en termes d'impact ou de modèle.";
    }

    function buildVigilance(a) {
      if (a.frein === 'demarches') {
        return "Les démarches admin freinent beaucoup d'activités dès le début. L'enjeu : ne pas laisser le flou administratif bloquer des décisions importantes — statut, charges, obligations.";
      }
      if (a.frein === 'visibilite') {
        return "Avoir une bonne offre ne suffit pas si personne ne la voit. Ton point de vigilance : construire une présence cohérente et continue, pas juste quelques posts isolés.";
      }
      if (a.frein === 'clients') {
        return "Trouver des clients, c'est souvent une question de méthode autant que de chance. L'enjeu : clarifier ton offre, identifier les bons canaux, et passer à une démarche plus active.";
      }
      if (a.frein === 'finances') {
        return "La gestion financière peut faire ou défaire une activité. Ton point de vigilance : comprendre tes charges réelles (cotisations, taxes), anticiper ta trésorerie, ne pas attendre d'être dans le rouge.";
      }
      if (a.frein === 'isolement') {
        return "L'isolement est souvent sous-estimé comme frein réel. Sans réseau, sans pairs, sans retours, on prend de mauvaises décisions ou on reste bloqué plus longtemps que nécessaire.";
      }
      return "Quel que soit ton stade, le risque principal reste de disperser ton énergie. Un cap clair sur ce qui compte vraiment maintenant, c'est ce qui permet d'avancer sans s'épuiser.";
    }

    function buildHelps(a) {
      var helps = [];
      if (a.frein === 'demarches' || a.statut === 'pas_encore') {
        helps.push('Clarifier ton statut juridique selon ton secteur et ta situation');
      }
      if (a.frein === 'finances' || a.statut === 'micro') {
        helps.push('Comprendre tes cotisations URSSAF et anticiper tes charges');
      }
      if (a.frein === 'visibilite' || a.priorite === 'visibilite') {
        helps.push('Construire une présence visible : pitch, offre, canaux adaptés à ton secteur');
      }
      if (a.frein === 'clients' || a.priorite === 'visibilite') {
        helps.push('Identifier les bons canaux pour trouver tes premiers clients ou en fidéliser');
      }
      if (a.frein === 'isolement' || a.priorite === 'reseau') {
        helps.push('Te connecter aux autres résidents Be-Cosmo et aux ressources collectives');
      }
      if (a.priorite === 'structurer' || a.avancement === 'idee') {
        helps.push('Poser les bases solides : structure, offre, premiers repères');
      }
      if (a.priorite === 'gestion') {
        helps.push('Mettre en place une gestion simple et lisible au quotidien');
      }
      return helps.slice(0, 3);
    }

    function buildHeadline(a) {
      var map = {
        demarches: 'Clarifier pour avancer sans freins admin.',
        visibilite: 'Rendre ton activité visible et lisible.',
        clients: 'Trouver les bons clients, pas juste du monde.',
        finances: 'Maîtriser tes finances pour avancer sereinement.',
        isolement: "Sortir de l'isolement et activer ton réseau."
      };
      return map[a.frein] || 'Structurer et développer ton activité.';
    }

    /* ────────────────────────────────────────────
       PROCESS & RENDER RESULT
    ──────────────────────────────────────────── */
    function processDiagnosis() {
      var a = answers;
      var scores   = computePillarScores(a);
      var top      = topPillars(scores, 2);
      var situation = buildSituation(a);
      var vigilance = buildVigilance(a);
      var helps     = buildHelps(a);
      var headline  = buildHeadline(a);

      var pillarNames = top.map(function(k) { return PILLARS[k].name; });
      var pillarsIntro = 'Sur la base de tes réponses, les piliers '
        + pillarNames.join(' et ')
        + ' sont les plus utiles pour toi maintenant.';

      document.getElementById('resHeadline').textContent = headline;
      document.getElementById('resSituation').textContent = situation;
      document.getElementById('resVigilance').textContent = vigilance;

      var listEl = document.getElementById('resHelps');
      listEl.innerHTML = helps.map(function(h) {
        return '<li>' + escHtml(h) + '</li>';
      }).join('');

      document.getElementById('resPillarsIntro').textContent = pillarsIntro;

      var grid = document.getElementById('resPillarsGrid');
      grid.innerHTML = ['lancer', 'exister', 'gerer', 'grandir'].map(function(k) {
        var p = PILLARS[k];
        var isActive = top.indexOf(k) !== -1;
        return '<div class="pillar-card' + (isActive ? ' active' : '') + '">'
          + '<p class="pillar-card-name">' + escHtml(p.name) + '</p>'
          + '<p class="pillar-card-desc">' + escHtml(p.desc) + '</p>'
          + '</div>';
      }).join('');

      var resCtaEl = document.getElementById('resCtaResources');
      if (resCtaEl && top[0]) {
        resCtaEl.href = '/ressources?pilier=' + top[0];
      }

      localStorage.setItem('orbete_v4_diag', JSON.stringify(a));

      var profile = {
        key: (a.avancement || 'projet') + '-' + (a.frein || 'general'),
        title: buildProfileTitle(a),
        summary: vigilance,
        theme: a.frein || 'general',
        themeLabel: buildThemeLabel(a),
        offerLevel: 1,
        offerName: 'Orbete',
        tags: buildTags(a),
        pillars: top,
        lieu: a.lieu || null,
        source: 'diagnostic'
      };

      try {
        var existing = JSON.parse(localStorage.getItem('orbete_profile') || '{}');
        localStorage.setItem('orbete_profile', JSON.stringify(Object.assign({}, profile, {
          firstName: existing.firstName || profile.firstName,
          plan: existing.plan || undefined
        })));
      } catch (e) {
        localStorage.setItem('orbete_profile', JSON.stringify(profile));
      }

      showView('view-result');
    }

    function buildProfileTitle(a) {
      var map = {
        idee:         'Porteur·se de projet',
        lance_recent: 'Entrepreneur·e en démarrage',
        en_dev:       'Entrepreneur·e en développement',
        bien_installe:'Résident·e établi·e'
      };
      return map[a.avancement] || 'Résident·e Be-Cosmo';
    }

    function buildThemeLabel(a) {
      var map = {
        demarches: 'Démarches & structure',
        visibilite: 'Visibilité & communication',
        clients:   'Développement commercial',
        finances:  'Gestion financière',
        isolement: 'Réseau & collectif'
      };
      return map[a.frein] || 'Développement activité';
    }

    function buildTags(a) {
      var tags = [];
      if (a.avancement === 'idee' || a.avancement === 'lance_recent') tags.push('démarrage');
      if (a.statut === 'pas_encore') tags.push('sans statut');
      if (a.statut === 'micro') tags.push('micro-entrepreneur');
      if (a.frein === 'demarches') tags.push('admin');
      if (a.frein === 'visibilite') tags.push('visibilité');
      if (a.frein === 'clients') tags.push('clients');
      if (a.frein === 'finances') tags.push('finances');
      if (a.frein === 'isolement') tags.push('réseau');
      if (a.secteur === 'artisanat') tags.push('artisanat');
      if (a.secteur === 'art') tags.push('art');
      if (!tags.length) tags.push('activité');
      return tags;
    }

    /* ────────────────────────────────────────────
       UTILS
    ──────────────────────────────────────────── */
    function escHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function esc(s) {
      return String(s).replace(/'/g, "\\'");
    }

    /* ────────────────────────────────────────────
       INIT
    ──────────────────────────────────────────── */
    document.getElementById('startBtn').addEventListener('click', function() {
      currentStep = 0;
      answers = {};
      showView('view-questions');
      renderDots(0);
      renderQuestion(0, 0);
    });

    document.getElementById('prevBtn').addEventListener('click', goPrev);
  </script>

</BaseLayout>
