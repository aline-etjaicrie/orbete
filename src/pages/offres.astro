---
import BaseLayout from '../layouts/BaseLayout.astro';
import InternalHeader from '../components/InternalHeader.astro';
---

<BaseLayout
  title="Offres & Tarifs — Orbete"
  description="Découvrez Orbete : votre copilote d'résident personnel ou l'outil partagé pour votre collectivité. Des offres adaptées à chaque besoin."
>
  
  <InternalHeader 
    label="Offres Orbete"
    title="Orbete, votre <em class='emphasis'>copilote d'résident·e</em>"
    subtitle="Un agent conversationnel conçu pour vous aider à comprendre, décider et agir dans votre projet. Des réponses claires, des outils concrets."
  />

  <main class="offres-v3">
    
    <!-- HERO SELECTION -->
    <section class="section-v3 offers-hero-v4">
      <div class="container-narrow text-center">
         <div class="offers-hero-panel">
            <p class="hero-note-v4">Choisissez votre point d’entrée : tester le copilote immédiatement, ou équiper une collectivité avec un cadre plus large.</p>
            <div class="hero-cta-group">
               <a href="/copilote" class="btn-primary-v3 big">Essayer gratuitement</a>
               <a href="#collectivites" class="btn-secondary-v3">Voir les offres collectivités</a>
            </div>
            <div class="hero-signals-v4">
               <div class="hero-signal-item">
                  <strong>Essai libre</strong>
                  <span>Une première question, tout de suite.</span>
               </div>
               <div class="hero-signal-item">
                  <strong>Usage individuel</strong>
                  <span>Un copilote personnel pour vos décisions et prises de parole.</span>
               </div>
               <div class="hero-signal-item">
                  <strong>Usage collectif</strong>
                  <span>Une mise à disposition simple pour vos résident·es et vos équipes.</span>
               </div>
            </div>
         </div>
      </div>
    </section>

    <!-- CE QUE VOUS TROUVEZ ICI -->
    <section class="section-v3 no-padding-top offers-utility-section">
      <div class="container">
        <div class="section-header section-header-left offers-section-head">
           <span class="label-v3">L'utilité</span>
           <h2>Être résident·e, c’est décider souvent, parfois seul·e, souvent vite.</h2>
           <p class="intro-v3">Orbete vous aide à retrouver un cadre clair avant d’agir, de parler ou d’arbitrer.</p>
        </div>

        <div class="utility-grid-v4">
           <article class="utility-card-v4">
              <span class="utility-num-v4">01</span>
              <h3>Prendre position</h3>
              <p>Quand vous devez trancher vite, sans perdre en justesse.</p>
           </article>
           <article class="utility-card-v4">
              <span class="utility-num-v4">02</span>
              <h3>Préparer une parole</h3>
              <p>Quand il faut expliquer, cadrer ou tenir une prise de parole sensible.</p>
           </article>
           <article class="utility-card-v4">
              <span class="utility-num-v4">03</span>
              <h3>Relire une situation</h3>
              <p>Quand un dossier, une tension ou une décision commencent à vous échapper.</p>
           </article>
        </div>
      </div>
    </section>

    <!-- OFFRE INDIVIDUELLE : AVANCER -->
    <section class="section-v3 plan-section-v4">
      <div class="container">
        <div class="plan-hero-v3">
           <div class="plan-header-v3">
              <span class="card-kicker text-red">Offre Individuelle</span>
              <h2>AVANCER</h2>
              <p class="intro-v3 opacity-70">Pour ne plus rester seul·e face aux décisions.</p>
              <div class="plan-price-v3">
                 <span class="amount">29€</span><span class="period">/mois</span>
              </div>
              <p class="plan-summary-v3">Un copilote personnel pour cadrer une décision, préparer une prise de parole ou retrouver du recul sur un dossier délicat.</p>
           </div>
           <div class="plan-features-v3">
              <p class="plan-list-label">Ce que vous activez</p>
              <ul class="v3-list-check-neon">
                 <li>Agent conversationnel complet</li>
                 <li>Aide à la décision sur des cas concrets</li>
                 <li>Préparation de prises de parole</li>
                 <li>Décryptage de situations locales</li>
                 <li>Diagnostic rapide pour prendre du recul</li>
              </ul>
              <p class="plan-footer-text">Pour les résident·es qui veulent aller vite, sans faire n’importe quoi.</p>
              <div class="plan-buttons-v3">
                 <button class="btn-primary-v3 checkout-btn" data-price-id="price_INDIVIDUAL_AVANCER" style="background:var(--neon);color:var(--deep);">S’abonner</button>
                 <a href="/copilote" class="btn-secondary-v3 dark">Essayer gratuitement</a>
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- OFFRE COLLECTIVITES -->
    <section id="collectivites" class="section-v3 bg-ivory">
      <div class="container">
        <div class="section-header text-center" style="margin-bottom: 5rem;">
           <span class="label-v3">Collectivités</span>
           <h2>Orbete pour votre <span class="emphasis">collectivité</span></h2>
           <p class="intro-v3">Un outil partagé au service de vos résident·es. Mise en place simple, coût maîtrisé, usage immédiat.</p>
        </div>

        <div class="pricing-grid-v3">
           <!-- Petite Commune -->
           <div class="price-bubble-v3 border-green">
              <span class="dot-v3 bg-green"></span>
              <h3>Petites communes</h3>
              <p class="size-label">(Jusqu'à 5 000 hab.)</p>
              <p class="price-v3">À partir de 50€/mois</p>
              <ul class="v3-list-dots">
                 <li>Accès pour quelques résident·es</li>
                 <li>Appui sur les décisions du quotidien</li>
                 <li>Préparation de prises de parole</li>
              </ul>
           </div>

           <!-- Intermédiaire -->
           <div class="price-bubble-v3 border-yellow">
              <span class="dot-v3 bg-yellow"></span>
              <h3>Communes intermédiaires</h3>
              <p class="size-label">(5 000 à 20 000 hab.)</p>
              <p class="price-v3">À partir de 100€/mois</p>
              <ul class="v3-list-dots">
                 <li>Accès élargi</li>
                 <li>Aide à la décision plus régulière</li>
                 <li>Décryptage de situations locales</li>
              </ul>
           </div>

           <!-- Ville -->
           <div class="price-bubble-v3 border-blue">
              <span class="dot-v3 bg-blue"></span>
              <h3>Villes et intercommunalités</h3>
              <p class="size-label">(20 000 à 100 000 hab.)</p>
              <p class="price-v3">À partir de 200€/mois</p>
              <ul class="v3-list-dots">
                 <li>Usage collectif (résident·es + cabinet)</li>
                 <li>Appui sur des sujets complexes</li>
                 <li>Accompagnement des prises de position</li>
              </ul>
           </div>

           <!-- Grande -->
           <div class="price-bubble-v3 border-red">
              <span class="dot-v3 bg-red"></span>
              <h3>Grandes collectivités</h3>
              <p class="size-label">Besoin spécifique</p>
              <p class="price-v3">Offre personnalisée</p>
              <ul class="v3-list-dots">
                 <li>Nombre d'utilisateurs adapté</li>
                 <li>Paramétrage sur-mesure</li>
                 <li>Appui renforcé</li>
              </ul>
           </div>
        </div>

        <!-- PERSONNALISATION -->
        <div class="custom-note-v3 card-v3">
           <div class="note-content-v3">
              <h3>Une offre <span class="emphasis">personnalisable</span></h3>
              <p>Parce qu'aucune collectivité ne fonctionne pareil, vous pouvez ajuster le nombre d'utilisateurs, les profils (résidents, cabinet, direction) et le niveau d'appui.</p>
           </div>
           <div class="note-cta-v3">
              <a href="/contact" class="btn-primary-v3">Équiper ma collectivité</a>
           </div>
        </div>
      </div>
    </section>

    <!-- TESTER 2 SEMAINES -->
    <section class="section-v3 no-padding-bottom">
       <div class="container container-medium">
          <div class="promo-banner-v3">
             <div class="promo-text-v3">
                <span class="badge-v3">2 semaines offertes</span>
                <h2>Mise à disposition gratuite</h2>
                <p>Accès complet, sans engagement. Le temps de voir concrètement si Orbete vous est utile avant d'ajuster l'offre.</p>
             </div>
             <a href="/contact" class="btn-primary-v3">Être rappelé</a>
          </div>
       </div>
    </section>

    <!-- CONCRETEMENT -->
    <section class="section-v3">
       <div class="container">
       <div class="section-header">
          <h2>Concrètement</h2>
          <p class="intro-v3">Orbete vous aide là où ça compte vraiment.</p>
        </div>
          <div class="use-cases-grid-v4">
             <article class="use-case-card-v4">
                <span class="use-case-index-v4">01</span>
                <p>Préparer un collectif Be-Cosmo</p>
             </article>
             <article class="use-case-card-v4">
                <span class="use-case-index-v4">02</span>
                <p>Exister rapidement un dossier</p>
             </article>
             <article class="use-case-card-v4">
                <span class="use-case-index-v4">03</span>
                <p>Arbitrer entre plusieurs options</p>
             </article>
             <article class="use-case-card-v4">
                <span class="use-case-index-v4">04</span>
                <p>Gérer une situation sensible</p>
             </article>
             <article class="use-case-card-v4">
                <span class="use-case-index-v4">05</span>
                <p>Formuler une prise de parole claire</p>
             </article>
          </div>
       </div>
    </section>

    <!-- POURQUOI PAS CHATGPT -->
    <section class="section-v3 diff-section-v4">
       <div class="container-narrow text-center">
          <span class="label-v3">La différence</span>
          <h2>Pourquoi pas juste <span class="emphasis">ChatGPT ?</span></h2>
          <div class="diff-grid-v3">
             <div class="diff-item">
                <p>Ici, vous n’avez pas à expliquer le fonctionnement des collectivités.</p>
             </div>
             <div class="diff-item">
                <p>Les réponses sont pensées pour des situations d’résidents locaux.</p>
             </div>
             <div class="diff-item">
                <p>L’objectif n’est pas d’informer, mais de vous aider à décider.</p>
             </div>
          </div>
          <p class="diff-footnote-v4">Orbete ne cherche pas seulement à produire du texte. Il aide à tenir un projet avec plus de clarté.</p>
          <p class="final-motto-v3">Un projet local, ça ne devrait pas se faire seul. <strong>Orbete est là pour ça.</strong></p>
       </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section-v3 text-center">
       <div class="container-narrow">
          <div class="offres-cta-v3">
             <a href="/copilote" class="btn-primary-v3 big">Essayer gratuitement</a>
             <a href="/contact" class="btn-secondary-v3">Équiper ma collectivité</a>
          </div>
       </div>
    </section>

  </main>
</BaseLayout>

<script>
  // STRIPE CLIENT INTEGRATION
  const checkoutButtons = document.querySelectorAll<HTMLButtonElement>('.checkout-btn');
  
  checkoutButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const priceId = target.dataset.priceId;
      
      if (!priceId) return;

      target.innerText = "Chargement...";
      target.disabled = true;

      try {
        const response = await fetch('/api/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            priceId: priceId,
            customerEmail: localStorage.getItem('user_email') || null 
          }),
        });
        
        const session = await response.json();
        
        if (session.url) {
          window.location.href = session.url;
        } else {
          alert("Erreur de session. Veuillez vérifier vos clés Stripe.");
          target.innerText = "S'abonner";
          target.disabled = false;
        }
      } catch (err) {
        console.error(err);
        alert("La connexion à Stripe a échoué.");
        target.innerText = "S'abonner";
        target.disabled = false;
      }
    });
  });
</script>

<style>
  .offres-v3 {
    --green: #22C55E;
    --yellow: #FACC15;
    --blue: #1B4332;
    --red: #EF4444;
    color: var(--deep);
  }

  .offres-v3 .section-v3:not(.bg-deep) :where(h1, h2, h3, h4) {
    color: var(--deep);
  }

  .offres-v3 .section-v3:not(.bg-deep) :where(p, li) {
    color: #54636c;
  }

  .plan-section-v4,
  .diff-section-v4 {
    background: linear-gradient(180deg, #fbf8f2 0%, #fffdfa 100%);
  }

  .bg-ivory {
    background: linear-gradient(180deg, #fbf8f2 0%, #f4efe6 100%);
  }

  .text-center {
    text-align: center;
  }

  .text-white {
    color: white !important;
  }

  .text-red {
    color: var(--accent-red) !important;
  }

  .opacity-70 {
    opacity: 0.72;
  }

  .no-padding-top {
    padding-top: 0;
  }

  .no-padding-bottom {
    padding-bottom: 0;
  }

  .offres-v3 .section-v3 {
    padding: 7rem 0;
  }

  .offres-v3 .section-header {
    max-width: 50rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .offres-v3 .section-header h2 {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    margin-bottom: 1rem;
    line-height: 1.04;
    letter-spacing: -0.03em;
  }

  .offres-v3 .intro-v3 {
    color: #54636c;
    font-size: 1.08rem;
    line-height: 1.65;
  }

  .section-header-left {
    text-align: left !important;
    max-width: 44rem !important;
    margin: 0 0 2.75rem !important;
  }

  .card-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.76rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .card-kicker::before {
    content: "";
    width: 10px;
    height: 2px;
    background: currentColor;
  }

  .offres-v3 .btn-primary-v3.big {
    min-width: 15rem;
  }

  .offers-hero-v4 {
    padding-top: 0;
    position: relative;
    overflow: hidden;
  }

  .offers-hero-v4::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(circle at center, black, transparent 78%);
  }

  .offers-hero-v4 .container-narrow {
    position: relative;
    z-index: 1;
  }

  .offers-hero-panel {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 249, 252, 0.98) 100%);
    border: 1px solid rgba(10, 25, 47, 0.08);
    border-radius: 2rem;
    padding: 2rem 2.2rem 2.15rem;
    box-shadow: 0 18px 40px rgba(10, 25, 47, 0.05);
  }

  .hero-note-v4 {
    margin: 0 auto 1.6rem;
    max-width: 42rem;
    color: var(--deep);
    font-size: 1rem;
    line-height: 1.6;
  }

  .hero-cta-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }

  .hero-signals-v4 {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .hero-signal-item {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border-radius: 1.1rem;
    background: rgba(10, 25, 47, 0.03);
    border: 1px solid rgba(10, 25, 47, 0.06);
    text-align: left;
  }

  .hero-signal-item strong {
    font-size: 0.92rem;
    color: var(--deep);
  }

  .hero-signal-item span {
    font-size: 0.84rem;
    line-height: 1.45;
    color: #54636c;
  }

  .offers-utility-section {
    background: linear-gradient(180deg, #fbf8f2 0%, #fffdfa 100%);
    border-top: 1px solid rgba(10, 25, 47, 0.05);
  }

  .utility-grid-v4 {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .utility-card-v4 {
    background: #fff;
    border: 1px solid rgba(10, 25, 47, 0.08);
    border-radius: 1.6rem;
    padding: 1.6rem;
    box-shadow: 0 14px 32px rgba(10, 25, 47, 0.04);
  }

  .utility-num-v4 {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.46);
  }

  .utility-card-v4 h3 {
    margin: 0 0 0.55rem;
    font-size: 1.2rem;
    line-height: 1.18;
  }

  .utility-card-v4 p {
    margin: 0;
    color: #54636c;
    line-height: 1.55;
    font-size: 0.96rem;
  }

  .plan-hero-v3 {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 2rem;
    background: linear-gradient(180deg, #ffffff 0%, #f8f3eb 100%);
    border: 1px solid rgba(10, 25, 47, 0.08);
    border-radius: 2rem;
    padding: 2.2rem;
    box-shadow: 0 24px 50px rgba(10, 25, 47, 0.06);
  }

  .plan-header-v3 {
    display: flex;
    flex-direction: column;
  }

  .plan-header-v3 h2 {
    margin: 0.8rem 0 0.7rem;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.98;
    color: var(--deep);
  }

  .plan-header-v3 .intro-v3 {
    color: #54636c;
    font-size: 1.12rem;
  }

  .plan-price-v3 {
    margin: 1.6rem 0 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
  }

  .plan-price-v3 .amount {
    font-size: clamp(3rem, 5vw, 4.8rem);
    font-weight: 800;
    color: var(--deep);
    line-height: 0.95;
  }

  .plan-price-v3 .period {
    font-size: 1.15rem;
    color: rgba(10, 25, 47, 0.58);
  }

  .plan-summary-v3 {
    margin: 0;
    max-width: 28rem;
    color: #54636c;
    line-height: 1.6;
    font-size: 0.98rem;
  }

  .plan-features-v3 {
    background: rgba(10, 25, 47, 0.03);
    border: 1px solid rgba(10, 25, 47, 0.08);
    border-radius: 1.6rem;
    padding: 1.6rem;
  }

  .plan-list-label {
    margin: 0 0 1rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(10, 25, 47, 0.62);
  }

  .v3-list-check-neon {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin: 0 0 1.5rem;
  }

  .v3-list-check-neon li {
    position: relative;
    padding-left: 1.55rem;
    color: var(--deep);
    line-height: 1.5;
  }

  .v3-list-check-neon li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--accent-red);
    transform: translateY(-50%);
  }

  .plan-footer-text {
    margin: 0 0 1.6rem;
    color: #54636c;
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .plan-buttons-v3 {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .pricing-grid-v3 {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
    margin-bottom: 2rem;
  }

  .price-bubble-v3 {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    background: #fff;
    padding: 2rem 1.55rem;
    border-radius: 1.6rem;
    border: 1px solid rgba(10, 25, 47, 0.08);
    border-top: 5px solid #eee;
    box-shadow: 0 14px 32px rgba(10, 25, 47, 0.04);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .price-bubble-v3:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 38px rgba(10, 25, 47, 0.06);
  }

  .dot-v3 {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: block;
    margin-bottom: 1.2rem;
  }

  .pricing-grid-v3 h3 {
    font-size: 1.12rem;
    margin: 0 0 0.5rem;
    line-height: 1.24;
  }

  .size-label {
    min-height: 2.6em;
    margin: 0 0 1rem;
    color: #6b7680;
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .price-v3 {
    font-weight: 800;
    font-size: 1rem;
    color: var(--deep);
    margin: 0 0 1.25rem;
  }

  .v3-list-dots {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.92rem;
    margin-top: auto;
  }

  .v3-list-dots li {
    position: relative;
    padding-left: 1rem;
    color: #54636c;
    line-height: 1.5;
  }

  .v3-list-dots li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.68rem;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: rgba(10, 25, 47, 0.24);
    transform: translateY(-50%);
  }

  .bg-green { background: var(--green); }
  .bg-yellow { background: var(--yellow); }
  .bg-blue { background: var(--blue); }
  .bg-red { background: var(--red); }
  .border-green { border-top-color: var(--green); }
  .border-yellow { border-top-color: var(--yellow); }
  .border-blue { border-top-color: var(--blue); }
  .border-red { border-top-color: var(--red); }

  .custom-note-v3 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: #fff;
    padding: 2rem 2.2rem;
