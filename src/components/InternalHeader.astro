---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  isDark?: boolean;
}

const { title, subtitle, label, isDark = false } = Astro.props;
---
<header class={`internal-header-v3 ${isDark ? 'dark' : ''}`}>
  <div class="container-narrow text-center">
    <div class="back-link-wrap">
      <a href="/" class="back-link-v3">← Retour à l'accueil</a>
    </div>
    {label && <span class="label-v3">{label}</span>}
    <h1 set:html={title} />
    {subtitle && <p class="intro-v3" set:html={subtitle} />}
  </div>
</header>

<style>
  .internal-header-v3 {
    padding: 8rem 0 4rem;
    background: transparent;
  }
  .internal-header-v3.dark {
    background: var(--deep);
    color: white;
  }
  .internal-header-v3.dark h1 { color: white; }
  .internal-header-v3.dark .label-v3 { color: white; }
  .internal-header-v3.dark .label-v3::before { background: white; }

  .back-link-wrap { margin-bottom: 2rem; }
  .back-link-v3 { 
    font-size: 0.85rem; 
    font-weight: 700; 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
    color: #54636C; 
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .back-link-v3:hover { opacity: 1; color: var(--accent-red); }
  .internal-header-v3.dark .back-link-v3 { color: white; opacity: 0.72; }
  .internal-header-v3.dark .back-link-v3:hover { color: white; opacity: 1; }
  
  h1 { 
    font-size: clamp(2.5rem, 6vw, 4rem); 
    margin: 1.5rem 0 2.5rem;
    line-height: 1.1;
  }
  .intro-v3 {
    font-size: 1.25rem;
    line-height: 1.6;
    color: #54636C;
    max-width: 700px;
    margin: 0 auto;
  }
  .internal-header-v3.dark .intro-v3 { color: white; opacity: 0.88; }
</style>
